<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Setup Your Profile — Antigravity</title>
  <link rel="stylesheet" href="/output.css"/>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css"/>
</head>
<body class="bg-gray-100">

  <!-- Nav -->
  <header class="bg-red-500 text-white p-4 shadow-md sticky top-0 z-10">
    <nav class="container mx-auto flex justify-between items-center">
      <a href="/" class="flex items-center gap-2 font-bold text-xl">
        <i class="fas fa-robot"></i> Antigravity
      </a>
      <a href="/logout" class="bg-white text-red-500 px-4 py-2 rounded-lg font-medium hover:bg-red-50 transition">
        Logout
      </a>
    </nav>
  </header>

  <main class="container mx-auto mt-8 p-8 bg-white rounded-lg shadow-md max-w-2xl">
    <h1 class="text-3xl font-bold mb-2 text-center text-gray-800 border-b pb-4">
      Welcome, <%= userName %>! 👋
    </h1>
    <p class="text-center text-gray-500 mb-8 text-sm">Tell us about yourself so we can personalize your AI experience.</p>

    <form action="/onboarding" method="POST" class="max-w-md mx-auto">

      <!-- Role -->
      <div class="mb-6">
        <label class="block text-sm font-medium text-gray-700 mb-3">
          <i class="fas fa-briefcase mr-1 text-red-500"></i> What is your primary role?
        </label>
        <div class="grid grid-cols-2 gap-3">
          <% [
            {val:'engineer',   icon:'fa-code',        label:'Engineer'},
            {val:'designer',   icon:'fa-pen-ruler',   label:'Designer'},
            {val:'product',    icon:'fa-layer-group', label:'Product Manager'},
            {val:'founder',    icon:'fa-rocket',      label:'Founder'},
            {val:'student',    icon:'fa-graduation-cap', label:'Student'},
            {val:'other',      icon:'fa-ellipsis',    label:'Other'}
          ].forEach(r => { %>
            <label class="flex items-center gap-2 p-3 border rounded-md cursor-pointer hover:border-red-500 hover:bg-red-50 transition has-[:checked]:border-red-500 has-[:checked]:bg-red-50">
              <input type="radio" name="role" value="<%= r.val %>" class="text-red-500 focus:ring-red-500" <%= r.val==='engineer'?'checked':'' %>/>
              <i class="fas <%= r.icon %> text-red-500 text-sm"></i>
              <span class="text-sm text-gray-700"><%= r.label %></span>
            </label>
          <% }) %>
        </div>
      </div>

      <!-- Experience Level -->
      <div class="mb-6 p-4 bg-gray-50 rounded-md border border-gray-200">
        <label class="block text-sm font-medium text-gray-700 mb-3">
          <i class="fas fa-chart-line mr-1 text-red-500"></i> Your experience level
        </label>
        <div class="flex gap-3 flex-wrap">
          <% [
            {val:'beginner',     label:'Beginner'},
            {val:'intermediate', label:'Intermediate'},
            {val:'advanced',     label:'Advanced'},
            {val:'expert',       label:'Expert'}
          ].forEach(l => { %>
            <label class="inline-flex items-center cursor-pointer">
              <input type="radio" name="level" value="<%= l.val %>" class="form-radio text-red-500 focus:ring-red-500" <%= l.val==='intermediate'?'checked':'' %>/>
              <span class="ml-2 text-gray-700 text-sm"><%= l.label %></span>
            </label>
          <% }) %>
        </div>
      </div>

      <!-- Goals -->
      <div class="mb-6">
        <label for="goals" class="block text-sm font-medium text-gray-700 mb-1">
          <i class="fas fa-bullseye mr-1 text-red-500"></i> What are your main goals? <span class="text-gray-400">(optional)</span>
        </label>
        <div class="relative">
          <span class="absolute top-3 left-3 text-gray-500">
            <i class="fas fa-pen"></i>
          </span>
          <textarea id="goals" name="goals" rows="3" placeholder="e.g. Build web apps, automate tasks, learn AI..."
            class="w-full pl-10 px-4 py-2 border rounded-md focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-red-500 transition resize-none"></textarea>
        </div>
      </div>

      <!-- Submit -->
      <button type="submit"
        class="w-full bg-red-500 text-white py-3 rounded-md hover:bg-red-600 focus:ring-4 focus:ring-red-300 font-medium transition duration-300 flex items-center justify-center">
        <span>Get Started</span>
        <i class="fas fa-arrow-right ml-2"></i>
      </button>
    </form>
  </main>

</body>
</html>
