<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --red: #ef4444; --red-dark: #dc2626; --red-light: #fef2f2;
    --gray-50: #f9fafb; --gray-100: #f3f4f6; --gray-200: #e5e7eb;
    --gray-400: #9ca3af; --gray-500: #6b7280; --gray-700: #374151; --gray-900: #111827;
    --white: #ffffff; --radius: 14px;
    --shadow-sm: 0 1px 3px rgba(0,0,0,.08);
    --shadow: 0 4px 16px rgba(0,0,0,.10);
    --shadow-lg: 0 10px 40px rgba(0,0,0,.14);
  }
  body { font-family: 'Inter', sans-serif; }
  a { text-decoration: none; color: inherit; }
</style>

<nav style="background:var(--red);color:#fff;position:sticky;top:0;z-index:100;box-shadow:0 2px 12px rgba(239,68,68,.3);font-family:'Inter',sans-serif;">
  <div style="max-width:1200px;margin:0 auto;padding:0 24px;height:58px;display:flex;align-items:center;justify-content:space-between;">

    <!-- LEFT -->
    <div style="display:flex;align-items:center;gap:4px;">
      <a href="/" style="font-size:1.1rem;font-weight:800;display:flex;align-items:center;gap:8px;margin-right:10px;letter-spacing:-.2px;">
        <i class="fas fa-robot"></i> Agent First
      </a>
      <% if (isLoggedIn) { %>
        <a href="/projects" style="display:flex;align-items:center;gap:6px;padding:7px 14px;border-radius:9px;font-size:.85rem;font-weight:500;background:<%= currentPage==='projects' ? 'rgba(0,0,0,.2)' : 'transparent' %>;transition:background .18s;" onmouseover="this.style.background='rgba(0,0,0,.18)'" onmouseout="this.style.background='<%= currentPage==='projects' ? 'rgba(0,0,0,.2)' : 'transparent' %>'">
          <i class="fas fa-folder-open" style="font-size:.75rem;"></i> Projects
        </a>
        <a href="/favourites" style="display:flex;align-items:center;gap:6px;padding:7px 14px;border-radius:9px;font-size:.85rem;font-weight:500;background:<%= currentPage==='favourites' ? 'rgba(0,0,0,.2)' : 'transparent' %>;transition:background .18s;" onmouseover="this.style.background='rgba(0,0,0,.18)'" onmouseout="this.style.background='<%= currentPage==='favourites' ? 'rgba(0,0,0,.2)' : 'transparent' %>'">
          <i class="fas fa-heart" style="font-size:.75rem;"></i> Favourites
        </a>
      <% } %>
    </div>

    <!-- RIGHT -->
    <div style="display:flex;align-items:center;gap:10px;">
      <% if (isLoggedIn) { %>
        <div style="display:flex;align-items:center;gap:8px;background:rgba(0,0,0,.18);padding:6px 14px;border-radius:9px;font-size:.85rem;font-weight:500;">
          <div style="width:26px;height:26px;border-radius:50%;background:#fff;color:var(--red);display:flex;align-items:center;justify-content:center;font-size:.75rem;font-weight:800;">
            <%= userName.charAt(0).toUpperCase() %>
          </div>
          <%= userName %>
        </div>
        <a href="/logout" style="border:1.5px solid rgba(255,255,255,.45);color:#fff;padding:7px 16px;border-radius:9px;font-size:.82rem;font-weight:500;display:flex;align-items:center;gap:6px;">
          <i class="fas fa-sign-out-alt" style="font-size:.75rem;"></i> Logout
        </a>
      <% } else { %>
        <a href="/signup" style="border:1.5px solid rgba(255,255,255,.45);color:#fff;padding:7px 18px;border-radius:9px;font-size:.85rem;font-weight:500;">Sign Up</a>
        <a href="/login"  style="background:#fff;color:var(--red);padding:7px 18px;border-radius:9px;font-size:.85rem;font-weight:600;">Login</a>
      <% } %>
    </div>

  </div>
</nav>
