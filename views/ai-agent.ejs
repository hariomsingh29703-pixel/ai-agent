<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/><meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>AI Agent Skill</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'Inter',sans-serif;background:#f1f5f9;min-height:100vh;color:#1e293b}

/* ── Navbar (HavenTo red-500) ── */
nav{background:#ef4444;color:#fff;padding:14px 32px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:100;box-shadow:0 2px 8px rgba(0,0,0,.15)}
.nav-brand{display:flex;align-items:center;gap:10px;font-size:1.1rem;font-weight:700;color:#fff;text-decoration:none}
.logo-icon{width:30px;height:30px;background:#dc2626;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:1rem;color:#fff;font-weight:700}
.nav-right{display:flex;align-items:center;gap:14px}
.nav-user-badge{display:flex;align-items:center;gap:8px;font-size:.82rem;color:rgba(255,255,255,.85)}
.avatar{width:34px;height:34px;border-radius:50%;background:#dc2626;border:2px solid rgba(255,255,255,.5);display:flex;align-items:center;justify-content:center;font-weight:700;font-size:.85rem;color:#fff}
.nav-logout{font-size:.82rem;color:#fff;text-decoration:none;border:1px solid rgba(255,255,255,.5);border-radius:8px;padding:6px 14px;transition:all .2s;background:transparent}
.nav-logout:hover{background:rgba(255,255,255,.15)}

/* ── Main layout ── */
main{max-width:1200px;margin:0 auto;padding:28px 20px 48px}

/* ── Hero section ── */
.hero{text-align:center;margin-bottom:28px}
.hero h1{font-size:2rem;font-weight:700;color:#1e293b;margin-bottom:8px}
.hero h1 span{color:#ef4444}
.hero p{color:#64748b;font-size:.93rem;line-height:1.65;max-width:600px;margin:0 auto}
.pills{display:flex;gap:8px;justify-content:center;flex-wrap:wrap;margin-top:14px}
.pill{background:#fff;border:1px solid #fecaca;color:#dc2626;font-size:.75rem;padding:5px 13px;border-radius:999px;font-weight:500;box-shadow:0 1px 3px rgba(0,0,0,.06)}

/* ── Permission overlay ── */
#perm-overlay{position:fixed;inset:0;background:rgba(15,23,42,.65);backdrop-filter:blur(6px);z-index:500;display:flex;align-items:center;justify-content:center}
#perm-overlay.hidden{display:none}
.perm-card{background:#fff;border-radius:20px;padding:40px 36px;max-width:480px;width:90%;text-align:center;box-shadow:0 20px 60px rgba(0,0,0,.25)}
.perm-icon{font-size:3rem;margin-bottom:16px}
.perm-card h2{font-size:1.4rem;font-weight:700;color:#1e293b;margin-bottom:10px}
.perm-card p{color:#64748b;font-size:.88rem;line-height:1.65;margin-bottom:26px}
.perm-options{display:flex;flex-direction:column;gap:12px;margin-bottom:26px;text-align:left}
.perm-toggle{background:#f8fafc;border:2px solid #e2e8f0;border-radius:12px;padding:14px 18px;display:flex;align-items:center;justify-content:space-between;gap:12px;cursor:pointer;transition:all .2s}
.perm-toggle:hover{border-color:#fca5a5;background:#fff5f5}
.perm-toggle.active{border-color:#ef4444;background:#fff5f5}
.perm-left{display:flex;align-items:center;gap:12px}
.perm-left span{font-size:1.4rem}
.perm-label{font-weight:600;font-size:.88rem;color:#1e293b}
.perm-desc{font-size:.75rem;color:#94a3b8;margin-top:2px}
.perm-check{width:22px;height:22px;border:2px solid #cbd5e1;border-radius:6px;display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:all .2s;color:#fff;font-size:.8rem}
.perm-toggle.active .perm-check{background:#ef4444;border-color:#ef4444}
.perm-actions{display:flex;gap:10px;justify-content:center}
.btn-primary{background:#ef4444;color:#fff;border:none;border-radius:10px;padding:11px 28px;font-size:.9rem;font-weight:600;cursor:pointer;font-family:'Inter',sans-serif;transition:background .2s}
.btn-primary:hover{background:#dc2626}
.btn-secondary{background:transparent;color:#64748b;border:1px solid #e2e8f0;border-radius:10px;padding:11px 20px;font-size:.9rem;cursor:pointer;font-family:'Inter',sans-serif;transition:all .2s}
.btn-secondary:hover{border-color:#94a3b8;color:#475569}

/* ── Permission status bar ── */
#perm-bar{background:#fff;border:1px solid #fecaca;border-radius:12px;padding:10px 18px;margin-bottom:18px;display:flex;align-items:center;justify-content:space-between;font-size:.82rem;color:#dc2626;box-shadow:0 1px 4px rgba(0,0,0,.06)}
#perm-bar.denied{background:#fff;border-color:#e2e8f0;color:#64748b}
#perm-bar.hidden{display:none}
.perm-bar-left{display:flex;align-items:center;gap:8px}
.perm-bar-btn{background:transparent;border:1px solid #fca5a5;color:#ef4444;border-radius:6px;padding:4px 12px;font-size:.75rem;cursor:pointer;font-family:'Inter',sans-serif;transition:all .2s}
.perm-bar-btn:hover{background:#fff5f5}

/* ── Layout ── */
.layout{display:flex;gap:20px;align-items:flex-start}
.chat-col{flex:1;min-width:0}
.files-col{width:275px;flex-shrink:0}

/* ── Chat card ── */
.card{background:#fff;border-radius:16px;box-shadow:0 2px 12px rgba(0,0,0,.08);border:1px solid #e2e8f0;overflow:hidden}
.chat-header{background:#ef4444;padding:15px 20px;display:flex;align-items:center;gap:12px}
.dot{width:9px;height:9px;background:#fff;border-radius:50%;opacity:.9;animation:pulse 2s infinite}
@keyframes pulse{0%,100%{opacity:.9}50%{opacity:.4}}
.chat-title{font-weight:600;font-size:.95rem;color:#fff}
.chat-sub{color:rgba(255,255,255,.75);font-size:.75rem;margin-top:1px}
#chat-box{height:380px;overflow-y:auto;padding:18px;display:flex;flex-direction:column;gap:10px;scroll-behavior:smooth;background:#f8fafc}
#chat-box::-webkit-scrollbar{width:4px}
#chat-box::-webkit-scrollbar-thumb{background:#fca5a5;border-radius:2px}
.msg{padding:11px 15px;border-radius:14px;max-width:92%;font-size:.86rem;line-height:1.6}
.ai-msg{background:#fff;border:1px solid #e2e8f0;align-self:flex-start;border-bottom-left-radius:4px;box-shadow:0 1px 3px rgba(0,0,0,.05)}
.ai-msg strong{color:#ef4444}
.user-msg{background:#ef4444;color:#fff;align-self:flex-end;border-bottom-right-radius:4px;box-shadow:0 2px 6px rgba(239,68,68,.3)}
.user-msg strong{color:rgba(255,255,255,.85)}
.err-msg{background:#fff5f5;border:1px solid #fecaca;align-self:flex-start;color:#dc2626}
.ai-out{font-family:'JetBrains Mono',monospace;font-size:.78rem;background:#f8fafc;border:1px solid #e2e8f0;border-radius:8px;padding:10px 13px;margin-top:7px;white-space:pre-wrap;word-break:break-word;color:#334155}

/* ── Suggestions ── */
.suggestions{display:flex;gap:7px;flex-wrap:wrap;padding:10px 18px;background:#fff;border-top:1px solid #f1f5f9}
.sug-btn{background:#fff5f5;border:1px solid #fecaca;color:#dc2626;border-radius:8px;padding:6px 13px;font-size:.74rem;cursor:pointer;font-family:'Inter',sans-serif;transition:all .2s;font-weight:500}
.sug-btn:hover{background:#ef4444;color:#fff;border-color:#ef4444}

/* ── Input area ── */
.input-area{border-top:1px solid #e2e8f0;padding:14px 18px;background:#fff}
#chat-form{display:flex;gap:10px}
#user-input{flex:1;background:#f8fafc;border:1px solid #e2e8f0;color:#1e293b;border-radius:10px;padding:10px 15px;font-size:.86rem;font-family:'Inter',sans-serif;outline:none;transition:border-color .2s}
#user-input:focus{border-color:#ef4444;background:#fff}
#user-input::placeholder{color:#94a3b8}
#send-btn{background:#ef4444;color:#fff;border:none;border-radius:10px;padding:10px 20px;font-size:.86rem;font-weight:600;cursor:pointer;font-family:'Inter',sans-serif;transition:background .2s}
#send-btn:hover{background:#dc2626}
#send-btn:disabled{opacity:.4;cursor:not-allowed}
#loading{display:none;align-items:center;gap:8px;padding:6px 0 0;color:#ef4444;font-size:.78rem}
#loading.on{display:flex}
.ld span{display:inline-block;width:5px;height:5px;background:#ef4444;border-radius:50%;animation:blink 1.4s infinite}
.ld span:nth-child(2){animation-delay:.2s}.ld span:nth-child(3){animation-delay:.4s}
@keyframes blink{0%,80%,100%{opacity:0}40%{opacity:1}}

/* ── Files panel ── */
.files-panel{background:#fff;border:1px solid #e2e8f0;border-radius:16px;overflow:hidden;box-shadow:0 2px 12px rgba(0,0,0,.08);position:sticky;top:80px}
.files-head{background:#ef4444;border-bottom:1px solid rgba(255,255,255,.2);padding:13px 16px;display:flex;align-items:center;justify-content:space-between}
.files-title{font-size:.85rem;font-weight:600;color:#fff;display:flex;align-items:center;gap:6px}
.ref-btn{background:rgba(255,255,255,.2);border:1px solid rgba(255,255,255,.4);color:#fff;border-radius:6px;padding:3px 10px;font-size:.75rem;cursor:pointer;font-family:'Inter',sans-serif;transition:all .2s}
.ref-btn:hover{background:rgba(255,255,255,.35)}
.ws-path{padding:8px 15px;font-family:'JetBrains Mono',monospace;font-size:.65rem;color:#94a3b8;border-bottom:1px solid #f1f5f9;word-break:break-all;background:#f8fafc}
#file-list{min-height:60px;max-height:380px;overflow-y:auto;padding:4px 0}
.f-item{display:flex;align-items:center;gap:8px;padding:8px 16px;cursor:pointer;transition:background .15s;font-size:.82rem}
.f-item:hover{background:#fff5f5}
.f-name{font-family:'JetBrains Mono',monospace;font-size:.76rem;color:#334155}
.f-empty{padding:22px 15px;text-align:center;color:#94a3b8;font-size:.78rem}

/* ── File viewer modal ── */
.modal-bg{display:none;position:fixed;inset:0;background:rgba(15,23,42,.65);backdrop-filter:blur(4px);z-index:300;justify-content:center;align-items:center}
.modal-bg.open{display:flex}
.modal{background:#fff;border-radius:16px;width:90%;max-width:780px;max-height:80vh;overflow:hidden;display:flex;flex-direction:column;box-shadow:0 25px 60px rgba(0,0,0,.2)}
.modal-head{padding:14px 20px;border-bottom:1px solid #e2e8f0;display:flex;justify-content:space-between;align-items:center;background:#ef4444}
.modal-fn{font-weight:600;color:#fff;font-size:.88rem;font-family:'JetBrains Mono',monospace}
.modal-x{background:rgba(255,255,255,.2);border:none;color:#fff;font-size:1.2rem;cursor:pointer;width:28px;height:28px;border-radius:6px;display:flex;align-items:center;justify-content:center}
.modal-x:hover{background:rgba(255,255,255,.35)}
#modal-content{flex:1;overflow-y:auto;padding:20px;font-family:'JetBrains Mono',monospace;font-size:.8rem;line-height:1.7;white-space:pre;color:#334155;background:#f8fafc}
.modal-foot{padding:10px 20px;border-top:1px solid #e2e8f0;display:flex;justify-content:space-between;align-items:center;font-size:.73rem;color:#94a3b8;background:#fff}
.copy-btn{background:#ef4444;color:#fff;border:none;border-radius:7px;padding:6px 14px;font-size:.73rem;cursor:pointer;font-family:'Inter',sans-serif;transition:background .2s}
.copy-btn:hover{background:#dc2626}

footer{text-align:center;padding:18px;color:#94a3b8;font-size:.73rem;border-top:1px solid #e2e8f0;background:#fff;margin-top:40px}
@media(max-width:768px){.layout{flex-direction:column}.files-col{width:100%;position:static}.hero h1{font-size:1.6rem}nav{padding:12px 16px}}
</style>
</head>
<body>

<!-- Permission Modal -->
<div id="perm-overlay" class="<%= permissionsGranted ? 'hidden' : '' %>">
  <div class="perm-card">
    <div class="perm-icon">🤖</div>
    <h2>Agent Permissions</h2>
    <p>To assist you, this agent needs your permission to create files and run commands <strong>on this server session</strong>. Your session is private — no other user can see your files.</p>
    <div class="perm-options">
      <div class="perm-toggle" id="toggle-files" onclick="togglePerm('files')">
        <div class="perm-left">
          <span>📁</span>
          <div>
            <div class="perm-label">File Creation Access</div>
            <div class="perm-desc">Allow the agent to create and save files in your workspace</div>
          </div>
        </div>
        <div class="perm-check" id="check-files"></div>
      </div>
      <div class="perm-toggle" id="toggle-terminal" onclick="togglePerm('terminal')">
        <div class="perm-left">
          <span>🖥️</span>
          <div>
            <div class="perm-label">Terminal Command Access</div>
            <div class="perm-desc">Allow the agent to run shell commands on this server</div>
          </div>
        </div>
        <div class="perm-check" id="check-terminal"></div>
      </div>
    </div>
    <div class="perm-actions">
      <button class="btn-secondary" onclick="grantPermissions(false, false)">Deny All</button>
      <button class="btn-primary" onclick="submitPermissions()">Grant Selected ✓</button>
    </div>
  </div>
</div>

<!-- Navbar -->
<nav>
  <a href="/" class="nav-brand">
    <div class="logo-icon">✦</div>
    AI Agent Skill
  </a>
  <div class="nav-right">
    <div class="nav-user-badge">
      <div class="avatar"><%- userName.charAt(0).toUpperCase() %></div>
      <span><%- userName %> · <span style="opacity:.75"><%- userRole %></span></span>
    </div>
    <a href="/logout" class="nav-logout">Logout</a>
  </div>
</nav>

<main>
  <!-- Hero -->
  <div class="hero">
    <h1>Autonomous <span>AI Agent</span></h1>
    <p>Powered by LangChain &amp; Groq. Ask the agent to build apps, run commands, or search the web — everything is saved to your private workspace.</p>
    <div class="pills">
      <span class="pill">🖥️ Terminal Commands</span>
      <span class="pill">📁 File Creation</span>
      <span class="pill">🔍 Web Search</span>
      <span class="pill">✍️ Code Generation</span>
    </div>
  </div>

  <!-- Permission status bar -->
  <div id="perm-bar" class="<%= permissionsGranted ? '' : 'hidden' %>">
    <div class="perm-bar-left">
      <span>🔐</span>
      <span id="perm-bar-text">Permissions active</span>
    </div>
    <button class="perm-bar-btn" onclick="showPermModal()">Change</button>
  </div>

  <div class="layout">
    <!-- Chat -->
    <div class="chat-col">
      <div class="card">
        <div class="chat-header">
          <div class="dot"></div>
          <div>
            <div class="chat-title">Antigravity Clone Agent</div>
            <div class="chat-sub">Connected · llama-4-scout · Groq</div>
          </div>
        </div>

        <div id="chat-box">
          <div class="msg ai-msg">
            <strong>Agent:</strong> Hey <strong><%- userName %></strong>! 👋 I'm your AI agent. As a <strong><%- userRole %></strong>, I can help you build apps, run commands, search the web, and create files — all from a single prompt. Try one of the suggestions below!
          </div>
        </div>

        <div class="suggestions">
          <button class="sug-btn" onclick="fill('Create a calculator web app in HTML and save it')">🧮 Calculator app</button>
          <button class="sug-btn" onclick="fill('List files in the current directory')">📁 List files</button>
          <button class="sug-btn" onclick="fill('Run echo Hello from AI Agent in the terminal')">🖥️ Run command</button>
          <button class="sug-btn" onclick="fill('Search the web for Python tips')">🔍 Web search</button>
          <button class="sug-btn" onclick="fill('Create a Python fibonacci script and save it')">🐍 Python script</button>
        </div>

        <div class="input-area">
          <form id="chat-form">
            <input type="text" id="user-input" placeholder="Ask the agent to build, run, or search..." autocomplete="off">
            <button type="submit" id="send-btn">▶ Send</button>
          </form>
          <div id="loading"><div class="ld"><span></span><span></span><span></span></div> Agent is thinking...</div>
        </div>
      </div>
    </div>

    <!-- Workspace Files -->
    <div class="files-col">
      <div class="files-panel">
        <div class="files-head">
          <div class="files-title">📂 Workspace Files</div>
          <button class="ref-btn" onclick="loadWorkspace()">↻ Refresh</button>
        </div>
        <div class="ws-path" id="ws-path">Your private session workspace</div>
        <div id="file-list"><div class="f-empty">Grant permissions &amp; ask the agent to create files</div></div>
      </div>
    </div>
  </div>
</main>

<footer>© 2024 AI Agent Skill · Built with Express.js, LangChain &amp; Groq</footer>

<!-- File viewer modal -->
<div class="modal-bg" id="modal-bg" onclick="closeMBg(event)">
  <div class="modal">
    <div class="modal-head">
      <div class="modal-fn" id="modal-fn">file.py</div>
      <button class="modal-x" onclick="closeModal()">×</button>
    </div>
    <pre id="modal-content">Loading...</pre>
    <div class="modal-foot">
      <span id="modal-path"></span>
      <button class="copy-btn" onclick="copyCode()">Copy</button>
    </div>
  </div>
</div>

<script>
// ── Permissions ───────────────────────────────────────────────────────────────
let permState = { files: false, terminal: false };

function togglePerm(type) {
  permState[type] = !permState[type];
  const el = document.getElementById('toggle-' + type);
  el.classList.toggle('active', permState[type]);
  document.getElementById('check-' + type).innerHTML = permState[type] ? '✓' : '';
}

function showPermModal() {
  document.getElementById('perm-overlay').classList.remove('hidden');
}

async function submitPermissions() {
  await grantPermissions(permState.files, permState.terminal);
}

async function grantPermissions(files, terminal) {
  try {
    const r = await fetch('/api/permissions', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ files, terminal })
    });
    const d = await r.json();
    if (d.success) {
      document.getElementById('perm-overlay').classList.add('hidden');
      const bar = document.getElementById('perm-bar');
      bar.classList.remove('hidden', 'denied');
      let parts = [];
      if (files) parts.push('📁 Files');
      if (terminal) parts.push('🖥️ Terminal');
      document.getElementById('perm-bar-text').textContent = parts.length
        ? '✅ Permissions: ' + parts.join(', ')
        : '⛔ No permissions granted — text only mode';
      if (!parts.length) bar.classList.add('denied');
      if (d.workspacePath) document.getElementById('ws-path').textContent = d.workspacePath;
      loadWorkspace();
    }
  } catch(e) { alert('Permission error: ' + e.message); }
}

// ── Workspace ─────────────────────────────────────────────────────────────────
async function loadWorkspace() {
  try {
    const r = await fetch('/api/workspace');
    const d = await r.json();
    if (d.path) document.getElementById('ws-path').textContent = d.path;
    const list = document.getElementById('file-list');
    if (!d.files || d.files.length === 0) {
      list.innerHTML = d.noPermission
        ? '<div class="f-empty">🔒 Grant file permission to see workspace</div>'
        : '<div class="f-empty">No files yet — ask the agent to create something!</div>';
      return;
    }
    list.innerHTML = d.files.map(f =>
      `<div class="f-item" onclick="${f.isDir ? '' : `openFile('${f.name}')`}">
        <span>${f.isDir ? '📁' : icon(f.name)}</span>
        <span class="f-name">${f.name}</span>
      </div>`
    ).join('');
  } catch(e) {}
}

function icon(n) {
  const m = {py:'🐍',js:'📜',html:'🌐',css:'🎨',ts:'🔷',json:'📋',md:'📝',txt:'📄',sh:'⚙️',go:'🔵',java:'☕'};
  return m[(n.split('.').pop()||'').toLowerCase()] || '📄';
}

async function openFile(name) {
  try {
    const r = await fetch('/api/workspace/read?file=' + encodeURIComponent(name));
    const d = await r.json();
    if (d.content !== undefined) {
      document.getElementById('modal-fn').textContent = name;
      document.getElementById('modal-content').textContent = d.content;
      document.getElementById('modal-path').textContent = d.path || name;
      document.getElementById('modal-bg').classList.add('open');
    }
  } catch(e) {}
}

function closeMBg(e) { if(e.target===document.getElementById('modal-bg')) closeModal(); }
function closeModal() { document.getElementById('modal-bg').classList.remove('open'); }
function copyCode() {
  navigator.clipboard.writeText(document.getElementById('modal-content').textContent).then(() => {
    const b = document.querySelector('.copy-btn'); b.textContent='Copied!';
    setTimeout(()=>b.textContent='Copy',2000);
  });
}

function fill(t) { document.getElementById('user-input').value=t; document.getElementById('user-input').focus(); }

// ── Chat ──────────────────────────────────────────────────────────────────────
document.getElementById('chat-form').addEventListener('submit', async e => {
  e.preventDefault();
  const inp = document.getElementById('user-input');
  const msg = inp.value.trim(); if (!msg) return;
  const box = document.getElementById('chat-box');

  const uDiv = document.createElement('div');
  uDiv.className = 'msg user-msg';
  uDiv.innerHTML = `<strong>You:</strong> ${msg.replace(/</g,'&lt;')}`;
  box.appendChild(uDiv); inp.value = '';
  box.scrollTop = box.scrollHeight;

  document.getElementById('loading').classList.add('on');
  document.getElementById('send-btn').disabled = true;

  try {
    const r = await fetch('/api/chat', {
      method:'POST', headers:{'Content-Type':'application/json'},
      body: JSON.stringify({ message: msg })
    });
    const d = await r.json();
    const aDiv = document.createElement('div');
    if (d.response) {
      aDiv.className = 'msg ai-msg';
      const safe = d.response.replace(/</g,'&lt;').replace(/>/g,'&gt;');
      aDiv.innerHTML = `<strong>Agent:</strong><div class="ai-out">${safe}</div>`;
      if (d.needsPermission) showPermModal();
      loadWorkspace();
    } else {
      aDiv.className = 'msg err-msg';
      aDiv.innerHTML = `<strong>⚠️ Error:</strong> ${(d.error||'Unknown error').replace(/</g,'&lt;')}`;
    }
    box.appendChild(aDiv);
  } catch(err) {
    const aDiv = document.createElement('div');
    aDiv.className = 'msg err-msg';
    aDiv.innerHTML = '<strong>⚠️ Connection Error:</strong> Could not reach the AI Agent.';
    box.appendChild(aDiv);
  } finally {
    document.getElementById('loading').classList.remove('on');
    document.getElementById('send-btn').disabled = false;
    box.scrollTop = box.scrollHeight;
  }
});

// Init
loadWorkspace();
</script>
